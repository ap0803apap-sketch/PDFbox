<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Select Button -->
    <Button
        android:id="@+id/btnAddFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Files" />

    <!-- Header -->
    <TextView
        android:id="@+id/tvSelectedHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selected Files"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

    <!-- Recycler -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMergeFiles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Merge Button -->
    <Button
        android:id="@+id/btnMerge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Merge Now"
        android:layout_marginTop="16dp" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No files selected" />
    </LinearLayout>

    <!-- Result -->
    <LinearLayout
        android:id="@+id/resultContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/tvMergedSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 KB" />

        <Button
            android:id="@+id/btnDownload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Download PDF" />
    </LinearLayout>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</LinearLayout>