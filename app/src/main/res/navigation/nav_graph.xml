<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_home">

    <!-- HOME -->
    <fragment
        android:id="@+id/nav_home"
        android:name="com.shejan.pdfbox_pdfeditor.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_viewer"
            app:destination="@id/navigation_viewer" />
    </fragment>

    <!-- RECENT -->
    <fragment
        android:id="@+id/nav_recent"
        android:name="com.shejan.pdfbox_pdfeditor.ui.recent.RecentFragment"
        android:label="Recent"
        tools:layout="@layout/fragment_recent">

        <action
            android:id="@+id/action_recent_to_viewer"
            app:destination="@id/navigation_viewer" />
    </fragment>

    <!-- TOOLS -->
    <fragment
        android:id="@+id/nav_tools"
        android:name="com.shejan.pdfbox_pdfeditor.ui.tools.ToolsFragment"
        android:label="Tools"
        tools:layout="@layout/fragment_tools" />

    <!-- SETTINGS -->
    <fragment
        android:id="@+id/nav_settings"
        android:name="com.shejan.pdfbox_pdfeditor.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <!-- VIEWER -->
    <fragment
        android:id="@+id/navigation_viewer"
        android:name="com.shejan.pdfbox_pdfeditor.ui.viewer.ViewerFragment"
        android:label="Viewer"
        tools:layout="@layout/fragment_viewer">

        <argument
            android:name="uri"
            app:argType="string" />
    </fragment>

    <!-- PDF TOOLS -->
    <fragment
        android:id="@+id/navigation_merge"
        android:name="com.shejan.pdfbox_pdfeditor.ui.merge.MergeFragment"
        android:label="Merge PDF"
        tools:layout="@layout/fragment_merge" />

    <fragment
        android:id="@+id/navigation_split"
        android:name="com.shejan.pdfbox_pdfeditor.ui.split.SplitFragment"
        android:label="Split PDF"
        tools:layout="@layout/fragment_split" />

    <fragment
        android:id="@+id/navigation_rotate"
        android:name="com.shejan.pdfbox_pdfeditor.ui.rotate.RotateFragment"
        android:label="Rotate PDF"
        tools:layout="@layout/fragment_rotate" />

    <fragment
        android:id="@+id/navigation_compress"
        android:name="com.shejan.pdfbox_pdfeditor.ui.compress.CompressFragment"
        android:label="Compress PDF"
        tools:layout="@layout/fragment_compress" />

    <fragment
        android:id="@+id/navigation_lock_unlock"
        android:name="com.shejan.pdfbox_pdfeditor.ui.security.LockUnlockFragment"
        android:label="Lock PDF"
        tools:layout="@layout/fragment_lock_unlock" />

    <fragment
        android:id="@+id/navigation_pdf_to_image"
        android:name="com.shejan.pdfbox_pdfeditor.ui.conversion.PdfToImageFragment"
        android:label="PDF to Image"
        tools:layout="@layout/fragment_pdf_to_image" />

    <fragment
        android:id="@+id/navigation_text_extraction"
        android:name="com.shejan.pdfbox_pdfeditor.ui.extraction.TextExtractionFragment"
        android:label="Text Extraction"
        tools:layout="@layout/fragment_text_extraction" />

</navigation>